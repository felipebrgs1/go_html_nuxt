{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gonx",
  "scopeName": "source.gonx",
  "patterns": [
    { "include": "#script-block" },
    { "include": "#style-block" },
    { "include": "#template-block" }
  ],
  "repository": {
    "template-block": {
      "begin": "(<)(template)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [
        { "include": "#interpolation" },
        { "include": "text.html.basic" }
      ]
    },
    "script-block": {
      "begin": "(<)(script)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.go",
      "patterns": [
        { "include": "source.go" }
      ]
    },
    "style-block": {
      "begin": "(<)(style)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.css",
      "patterns": [
        { "include": "source.css" }
      ]
    },
    "interpolation": {
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.gonx" }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.gonx" }
      },
      "contentName": "source.go",
      "patterns": [
        {
          "match": "\\b(call|range|if|else|end)\\b",
          "name": "keyword.control.gonx"
        },
        { "include": "source.go" }
      ]
    }
  }
}
